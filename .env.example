# WhatsApp Expense Diary — Environment Variables
# Copy to .env for local dev. On Render, set these in the dashboard.
# NEVER commit .env to git. This file must contain PLACEHOLDERS only.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
LOGLEVEL=INFO

# ── Meta WhatsApp Cloud API ───────────────────────────────────────────────────
# From Meta Developer → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=your_meta_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=choose_any_random_string_you_invent
WHATSAPP_APP_SECRET=your_meta_app_secret
WHATSAPP_API_VERSION=v21.0

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=expense-reports

# ── Encryption (generate once — changing these breaks all existing user data) ─
# python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_SECRET=generate_a_secret_at_least_32_characters_long

# python -c "import secrets; print(secrets.token_hex(16))"
PHONE_LOOKUP_SALT=generate_a_salt_at_least_16_characters

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# ── Paystack ─────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_or_sk_live_your_paystack_secret
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# ── Cron job protection ─────────────────────────────────────────────────────
# python -c "import secrets; print(secrets.token_hex(16))"
CRON_SECRET=generate_a_random_cron_secret
